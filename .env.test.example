# ==================== Database Configuration ====================
# Set complete DSNs directly here using the SQLX_*_DSN namespace.
# Set to "skip" to skip tests for that database.

SQLX_MYSQL_DSN="root:xxx@tcp(127.0.0.1:3306)/test?parseTime=true"
SQLX_POSTGRES_DSN="postgres://postgres:xxxxx@127.0.0.1:5432/test?sslmode=disable"
SQLX_SQLSERVER_DSN="sqlserver://sa:xxx@127.0.0.1:1433?database=test&encrypt=disable"
# Skip a specific driver:
# SQLX_MYSQL_DSN="skip"
# SQLX_POSTGRES_DSN="skip"


# ==================== Alternative DSN Examples ====================
# MySQL with custom parameters:
# SQLX_MYSQL_DSN="user:password@tcp(127.0.0.1:3306)/dbname?parseTime=true&charset=utf8mb4&loc=Local"

# MySQL via Unix socket:
# SQLX_MYSQL_DSN="user:password@unix(/tmp/mysql.sock)/dbname?parseTime=true"

# PostgreSQL with SSL:
# SQLX_POSTGRES_DSN="postgres://user:password@127.0.0.1:5432/dbname?sslmode=require"

# PostgreSQL with quoted special characters in password:
# SQLX_POSTGRES_DSN="postgres://user:p%40ssw0rd@127.0.0.1:5432/dbname?sslmode=disable"

# SQLite file-based:
# SQLX_SQLITE_DSN="/path/to/test.db"

# Oracle:
# SQLX_ORACLE_DSN="oracle://user:password@127.0.0.1:1521/service_name"

# SQL Server:
# SQLX_SQLSERVER_DSN="sqlserver://user:password@127.0.0.1:1433?database=test&encrypt=disable"

